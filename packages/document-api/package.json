{
  "name": "@superdoc/document-api",
  "version": "0.1.0-alpha.0",
  "description": "Contract-first, engine-agnostic SuperDoc Document API surface. Most consumers should depend on higher-level SuperDoc runtime packages.",
  "license": "AGPL-3.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "build:clean": "rm -rf dist tsconfig.tsbuildinfo && pnpm run build",
    "prepack": "pnpm run build:clean",
    "prepublishOnly": "pnpm run build:clean",
    "test": "bun test"
  },
  "publishConfig": {
    "access": "public"
  }
}
