# R2 configuration for visual testing.
# Account ids and bucket names are env-only — there are no in-repo defaults.

# --- Baselines / screenshots bucket (scripts/r2.ts) ---
# Always required:
# SD_VISUAL_TESTING_R2_ACCOUNT_ID=
# SD_VISUAL_TESTING_R2_BUCKET=

# --- Shared test-document corpus (scripts/corpus/*, docs:download / docs:upload) ---
# Always required:
# SUPERDOC_CORPUS_R2_ACCOUNT_ID=
# SUPERDOC_CORPUS_R2_BUCKET=

# --- Authentication ---
# Option 1: Wrangler login (recommended for local dev)
# Run: npx wrangler login
# No credential env vars needed — auth uses your Cloudflare account token.
#
# Option 2: R2 API credentials (used by CI)
# SD_VISUAL_TESTING_R2_ACCESS_KEY_ID=
# SD_VISUAL_TESTING_R2_SECRET_ACCESS_KEY=
# SUPERDOC_CORPUS_R2_ACCESS_KEY_ID=
# SUPERDOC_CORPUS_R2_SECRET_ACCESS_KEY=
